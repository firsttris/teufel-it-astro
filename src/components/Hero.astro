---
import ProfileLink from "./ProfileLink.astro";
import { useTranslations } from "./../i18n/utils";

const t = useTranslations(Astro.url.pathname);
---

<section
  class="relative isolate flex flex-col items-center justify-center min-h-screen py-20 overflow-hidden"
>
  <div
    class="relative z-10 container mx-auto px-6 md:px-12 flex flex-col items-center text-center gap-10"
  >
    <!-- Badge / Tagline -->

    <!-- Main Heading -->
    <h1
      class="text-6xl md:text-8xl font-black tracking-tight text-white max-w-5xl leading-[1.1] reveal"
    >
      Tristan Teufel
      <br />
      <span
        class="text-transparent bg-clip-text animate-gradient-text"
      >
        Software Architect
      </span>
    </h1>

    <!-- Subheading -->
    <p
      class="text-xl md:text-2xl text-zinc-400 max-w-2xl font-light leading-relaxed reveal reveal-delay-2"
    >
      Building the foundation for your developer experience.
    </p>

    <!-- Quote -->
    <blockquote
      class="text-lg md:text-xl text-zinc-500 italic max-w-2xl reveal reveal-delay-3"
    >
      &ldquo;{t("hero.quote")}&rdquo;
    </blockquote>

    <!-- CTAs / Links -->
    <div class="flex flex-wrap justify-center gap-4 pt-4 reveal reveal-delay-4">
      <ProfileLink
        name="Github"
        icon="simple-icons:github"
        link="https://github.com/firsttris"
        class="bg-zinc-100 text-zinc-950 hover:bg-white border-transparent"
      />
      <ProfileLink
        name="LinkedIn"
        icon="simple-icons:linkedin"
        link="https://www.linkedin.com/in/tristanteufel/"
        class="bg-white/5 text-white hover:bg-white/10 border-white/10"
      />
      <ProfileLink
        name={t("cv") as string}
        icon="mdi:file-account"
        link="https://cv.teufel-it.de"
        class="bg-white/5 text-white hover:bg-white/10 border-white/10"
      />
      <ProfileLink
        name="Email"
        icon="mdi:email"
        link="mailto:info@teufel-it.de"
        class="bg-white/5 text-white hover:bg-white/10 border-white/10"
      />
    </div>
  </div>
</section>

<style>
  @keyframes gradientTextFlow {
    0% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .animate-gradient-text {
    display: inline-block;
    color: transparent;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    -webkit-background-clip: text;
    background-image: repeating-linear-gradient(
      90deg,
      #22d3ee 0%,
      #3b82f6 34%,
      #a855f7 50%,
      #3b82f6 66%,
      #22d3ee 100%
    );
    background-size: 200% 100%;
    background-repeat: no-repeat;
    animation: gradientTextFlow 18s ease-in-out infinite alternate;
  }
</style>
